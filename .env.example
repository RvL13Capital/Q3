# Copy this file to .env and fill in your API keys
# .env is gitignored — never commit real keys
#
# For GitHub Actions, add each key as a repository secret at:
#   Settings → Secrets and variables → Actions → New repository secret

# ── REQUIRED ────────────────────────────────────────────────────────────────

# FRED (Federal Reserve Economic Data) — free, instant signup
# Get key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── OPTIONAL (but recommended) ───────────────────────────────────────────────

# EODHD — paid, ~$20/mo "All-World" plan
# Needed for EU/CA fundamental data (IFRS). Without it, yfinance is used as
# fallback — quality_score confidence will be lower for EU/CA stocks.
# Get key at: https://eodhd.com/pricing
EODHD_API_KEY=your_eodhd_api_key_here

# Second EODHD key for rate-limit rotation (optional — omit if only one key)
EODHD_API_KEY_2=your_eodhd_backup_key_here
